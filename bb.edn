{:paths ["." "src" "test"]
 :tasks
 {test {:doc "Run tadori murakumo actor boundary tests"
        :task (do
                (require 'clojure.test
                         'tadori.murakumo-test)
                (let [run-tests (requiring-resolve 'clojure.test/run-tests)
                      r (run-tests 'tadori.murakumo-test)]
                  (System/exit (if (zero? (+ (:fail r) (:error r))) 0 1))))}}}
