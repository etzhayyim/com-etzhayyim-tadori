;; tadori — kotoba Datomic schema for passive threat-intel observations.
;; ADR-2605301400 T3 bridge: yabai CTI/DNS/IP-history/access-audit -> kotoba.
;;
;; This schema holds SecurityTrails/DNSDB/Recorded Future-shaped observations
;; only as operator-staged evidence datoms. Proprietary/vendor feeds are never
;; the system of record; source role must be recorded on every observation.

[;; Source metadata ---------------------------------------------------------
 {:db/id "tadori.source/id"
  :db/ident :tadori.source/id
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/unique :db.unique/identity
  :db/doc "Stable source id, e.g. source:public-ct-log:crtsh or source:vendor-compatible:securitytrails"}
 {:db/id "tadori.source/name"
  :db/ident :tadori.source/name
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one}
 {:db/id "tadori.source/vendor-family"
  :db/ident :tadori.source/vendor-family
  :db/valueType :db.type/keyword
  :db/cardinality :db.cardinality/one
  :db/doc ":public-archive | :securitytrails-compatible | :dnsdb-compatible | :recordedfuture-compatible | :operator-staged"}
 {:db/id "tadori.source/source-role"
  :db/ident :tadori.source/source-role
  :db/valueType :db.type/keyword
  :db/cardinality :db.cardinality/one
  :db/doc ":system-of-record is allowed only for open/public archives; proprietary families must use :feature-flagged-input"}
 {:db/id "tadori.source/license-tier"
  :db/ident :tadori.source/license-tier
  :db/valueType :db.type/keyword
  :db/cardinality :db.cardinality/one
  :db/doc ":A | :B | :C | :D. Tier-D requires explicit operator override and remains non-SoR."}
 {:db/id "tadori.source/dataset-cid"
  :db/ident :tadori.source/dataset-cid
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one
  :db/doc "CID of the operator-staged snapshot or archive shard."}
 {:db/id "tadori.source/captured-at"
  :db/ident :tadori.source/captured-at
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one}
 {:db/id "tadori.source/notes"
  :db/ident :tadori.source/notes
  :db/valueType :db.type/string
  :db/cardinality :db.cardinality/one}

