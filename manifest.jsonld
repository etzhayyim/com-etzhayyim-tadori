  "constitutionalGates": {
    "description": "12 immutable gates per ADR-2605301400 §D1. Council Lv6+ supermajority + new ADR to amend; §1.12 Transparent-Force items are Lv7+ (Preamble §0.4).",
    "gates": {
      "G1": "Charter Rider §2(a)-(h) scan on any ingested/generated text (etzhayyim_organism.sensors.charter_rider.scan); fail = block",
      "G2": "kotoba datom lineage — append-only EAVT; corrections via supersededBy, no soft delete",
      "G3": "AUTHORIZED-INVESTIGATION-ONLY — every live write references an active caseMandate + authorizationRef; no case → Phase 0 dry-run; noncaseWriteCount=0",
      "G4": "OPEN-SOURCE — no proprietary chain-analysis as system of record; external paid sources feature-flagged inputs only; proprietarySorCount=0",
      "G5": "ON-CHAIN-MONITORABLE — Transparent Force audit datom per case action (Charter §1.12 + ADR-2605192315); caseMandate.transparentForceLogged const true",
      "G6": "PII-ENCRYPTED — person/IP/device attribution under com.etzhayyim.encrypted.* Signal-wrapped to case-members (ADR-2605181100); plaintextPiiCount=0",
      "G7": "EVIDENCE-ONLY / NO ENFORCEMENT — enforcement routes via yabai + Council; enforcementActionCount=0",
      "G8": "NO PLATFORM-HELD KEY (ADR-2605231525) — member / community-operator signed; platformHeldKeyCount=0",
      "G9": "Murakumo-only inference (ADR-2605215000); murakumoBypassCount=0",
      "G10": "NO MASS SURVEILLANCE / NO ADHERENT DE-ANON — case-scoped only; massSurveillanceCount=0; adherentDeanonCount=0",
      "G11": "kotoba substrate only (ADR-2605262130) — no yata SQL / RisingWave / Postgres / SQLite; nonKotobaStoreCount=0",
      "G12": "Bonsai pruning (ADR-2605091800) — any silenTadoriReview nonzero counter → seed-tier prune (full freeze + human review + chigiri.disputeMediation)"
    }
  },
  "nonGoals": {
