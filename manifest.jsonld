  "crossActorProcedure": [
    "did:web:malak.etzhayyim.com (compute source — wallet_deep_inspect_pursuit + address_label_pursuit Pregels; tadori persists their output as durable datoms)",
    "did:web:ipaddress.etzhayyim.com (1次 source — ip-obs / dns-obs datoms post-T2 migration)",
    "did:web:yabai.etzhayyim.com (risk + enforcement-routing sink — tadori produces evidence datoms; yabai scores; Council authorizes enforcement)",
    "did:web:chigiri.etzhayyim.com (dispute mediation sink — any silenTadoriReview nonzero counter routes to chigiri.disputeMediation)"
  ],
  "form": "任意団体 internal authorized-investigation substrate (NOT a commercial chain-analysis service; non-profit only — Preamble §0.4 Lv7+ unanimity lock)",
  "capabilityCeiling": {
    "constitutional": true,
    "authorizedInvestigationOnly": "Every live write MUST reference an active caseMandate carrying an authorizationRef (fraud-victim-recovery / aml-cti-duty / sanctioned-entity-tracing / council-transparent-force). No case → Phase 0 dry-run only. Structural: caseMandate required; silenTadoriReview.noncaseWriteCount const 0 (G3).",
    "openSource": "No proprietary chain-analysis algorithm is the system of record. External paid sources (Chainalysis / Elliptic / TRM / Crystal) are feature-flagged INPUTS to a label/traceReport only, recorded in externalSourcesUsed. silenTadoriReview.proprietarySorCount const 0 (G4).",
    "onChainMonitorable": "Every case action emits an on-chain-anchored Transparent Force audit datom (Charter §1.12 + ADR-2605192315). caseMandate.transparentForceLogged const true (G5).",
    "piiEncrypted": "person / IP / device attribution datoms are written under the com.etzhayyim.encrypted.* envelope, Signal-wrapped to the authorized case-member DIDs only (ADR-2605181100). attributionFinding.encrypted required true for those objectKinds; silenTadoriReview.plaintextPiiCount const 0 (G6).",
    "evidenceOnlyNotEnforcement": "tadori produces evidence datoms. It MUST NOT initiate enforcement; enforcement routes through yabai (risk) + Council. silenTadoriReview.enforcementActionCount const 0 (G7).",
    "noPlatformHeldKey": "Writes are member-signed (case-member DID) or community-operator DID (bulk ingest). tadori holds no platform private key (ADR-2605231525). silenTadoriReview.platformHeldKeyCount const 0 (G8)."
  },
  "scope": {
    "phase": "R0 scaffold",
    "scopeBoundary": "Authorized, case-anchored on-chain transaction tracing + cross-store actor attribution, evidence-producing, persisted to kotoba-kqe EAVT",
    "exclusions": [
      "enforcement / takedown / asset-freeze action (that is yabai + Council)",
      "active probing / scanning / network reconnaissance (negative-space; sources are passive 1次 collectors + on-chain)",
      "untargeted / non-case-scoped mass surveillance",
      "de-anonymizing an etzhayyim adherent",
      "proprietary chain-analysis as the system of record (Chainalysis / Elliptic / TRM / Crystal — feature-flagged input only)",
      "plaintext PII (person / IP / device) — must use com.etzhayyim.encrypted.*",
      "holding any platform master/signing key (ADR-2605231525)",
      "live write without an active caseMandate",
      "vendor / commercial-GPU LLM callout (Murakumo-only per ADR-2605215000)",
      "yata SQL / RisingWave / Postgres / SQLite store (kotoba-only per ADR-2605262130)",
      "state-aligned / military tracing operations (Charter §1.12)"
    ]
  },
